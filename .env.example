# Скопировать в .env и заполнить значения:
#   cp .env.example .env

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme        # ОБЯЗАТЕЛЬНО заменить
POSTGRES_DB=lectures
POSTGRES_PORT=5433
POSTGRES_HOST=localhost

# =============================================================================
# Milvus (векторная БД)
# =============================================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=lectures

# =============================================================================
# MinIO (хранилище для Milvus)
# =============================================================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin       # рекомендуется заменить на проде
MINIO_PORT=9001

# =============================================================================
# Etcd (для Milvus)
# =============================================================================
ETCD_PORT=2379

# =============================================================================
# Docker network
# =============================================================================
DOCKER_SUBNET=172.50.0.0/16

# =============================================================================
# LLM (OpenAI-compatible endpoint)
# =============================================================================
LLM_URL=http://your-llm-server:1234/v1   # ОБЯЗАТЕЛЬНО указать
LLM_NAME=your-model-name                  # ОБЯЗАТЕЛЬНО указать
LLM_API_KEY=not-needed                    # для локальных серверов часто not-needed

# =============================================================================
# HuggingFace (для pyannote-диаризации)
# =============================================================================
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # ОБЯЗАТЕЛЬНО

# =============================================================================
# Embeddings
# =============================================================================
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# =============================================================================
# RAG Settings
# =============================================================================
RAG_CHUNK_SIZE=2500
RAG_CHUNK_OVERLAP=128
RAG_TOP_K=5
RAG_MAX_ITERATIONS=3
